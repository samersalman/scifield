# Copy this file to `.env` and fill in your real keys. `.env` is gitignored.
# Never paste your real key into this file — only into `.env`.

# DeepSeek API key for V1-S08 epistemic extraction (transport: deepseek).
# Get one at https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-your-key-here

# Optional: override the API base URL (defaults to https://api.deepseek.com).
# DEEPSEEK_BASE_URL=https://api.deepseek.com
